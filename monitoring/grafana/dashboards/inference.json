{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {"unit": "reqps"},
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(request_count_total[1m])",
          "legendFormat": "{{endpoint}} - {{status}}"
        }
      ]
    },
    {
      "title": "Request Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {"unit": "s"},
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(request_latency_seconds_bucket[5m]))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(request_latency_seconds_bucket[5m]))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(request_latency_seconds_bucket[5m]))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "title": "Total Requests",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(request_count_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8},
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.01}]}},
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(request_count_total{status=~\"4..|5..\"}[5m])) / sum(rate(request_count_total[5m]))",
          "legendFormat": "Error %"
        }
      ]
    },
    {
      "title": "GPU Memory Used (GB)",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "min": 0,
          "max": 24,
          "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 16}, {"color": "red", "value": 22}]}
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "gpu_memory_used_bytes / 1073741824",
          "legendFormat": "GPU Memory"
        }
      ]
    },
    {
      "title": "Model Status",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8},
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}]
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "model_loaded",
          "legendFormat": "Status"
        }
      ]
    },
    {
      "title": "Latency by Endpoint",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "fieldConfig": {
        "defaults": {"unit": "s"},
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(request_latency_seconds_bucket{endpoint=\"/solve\"}[5m]))",
          "legendFormat": "/solve P95"
        },
        {
          "expr": "histogram_quantile(0.95, rate(request_latency_seconds_bucket{endpoint=\"/batch\"}[5m]))",
          "legendFormat": "/batch P95"
        }
      ]
    },
    {
      "title": "Request Count by Status",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {
          "expr": "sum by (status) (request_count_total)",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["math-reasoning", "inference"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "title": "Math Reasoning API - Inference Monitoring",
  "uid": "math-reasoning-inference"
}
